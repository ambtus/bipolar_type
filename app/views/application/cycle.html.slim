table
  caption
    b the Normal cycle
  tr
    td.none.middle.third
    td.top.third
      b=Mood.e.title
      br
      | change bad things
    td.none.middle.third
  tr
    td.middle
      b=Mood.p.title
      .left accept things until they are bad, then change them.
    th &orarr;
    td.middle
      b=Mood.j.title
      .left change things until they are good, then accept them.
  tr
    td.none.middle
    td.bottom
      b=Mood.i.title
      br
      | accept good things
    td.none.middle

