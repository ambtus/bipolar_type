  caption
    b the Bipolar cycle
  tr
    td.none.third
    td.third
      b=Mood.e.bipolar
      .left changing things that are <em>not</em> bad!
      | (too much courage;<br />not enough serenity)
    td.none.third
  tr
    td
      b=Mood.p.bipolar
      .left I do not <em>know</em> whether they are bad enough to change!
      | (not enough wisdom)
    th &orarr;
    td
      b=Mood.j.bipolar
      .left I do not <em>know</em> whether they are good enough to accept!
      | (not enough wisdom)
  tr
    td
    td
      b=Mood.i.bipolar
      .left accepting things that are <em>not</em> good!
      | (too much serenity;<br />not enough courage)
