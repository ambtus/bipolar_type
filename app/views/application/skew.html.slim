table
  caption
    b your Wise cycle
  tr
    td.none.middle.third
    -realm = @realms.second
    td.third #{realm.title.ly} #{Mood.e.wise}
    td.none.middle.third
  tr
    -realm = @realms.first
    td.middle #{realm.title.ly} #{Mood.p.wise}
    th &orarr;
    -realm = @realms.third
    td.middle #{realm.title.ly} #{Mood.j.wise}
  tr
    td.none.middle
    -realm = @realms.fourth
