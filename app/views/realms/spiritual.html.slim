  caption The Four Subtypes
  tr
    td.p=render 'subtype', b: Behavior.efp
    td.p=render 'subtype', b: Behavior.efj
  tr
    td.p=render 'subtype', b: Behavior.ifp
    td.p=render 'subtype', b: Behavior.ifj
